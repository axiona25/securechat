# Copia in .env.development e modifica se serve.
#
# Backend remoto (default come prima del refactor env):
#   REACT_APP_API_BASE=https://axphone.it/api
#   REACT_APP_SITE_ORIGIN=https://axphone.it
#
# Backend Django locale:
#   REACT_APP_API_BASE=http://127.0.0.1:8000/api
#   REACT_APP_SITE_ORIGIN=http://127.0.0.1:8000
#
# CORS: in produzione il server deve consentire http://localhost:3000 in CORS_ALLOWED_ORIGINS,
# altrimenti il browser bloccherà le fetch. In dev Django (dev.py) CORS è già permissivo.

REACT_APP_API_BASE=https://axphone.it/api
REACT_APP_SITE_ORIGIN=https://axphone.it
